# LLM Provider Configuration
# Priority: Moonshot Kimi → Anthropic Claude → Demo mode (first key found wins)
# Copy this file to .env and fill in your keys.

# ── Moonshot Kimi ─────────────────────────────────────────────────────────
# Get your key from: platform.moonshot.cn → API Keys
LLM_PROVIDER=moonshot
MOONSHOT_API_KEY=sk-kimi-your-key-here
MOONSHOT_MODEL=kimi-k2
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# ── Anthropic Claude (fallback / inactive when Moonshot key is set) ─────────
# Get your key from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Mock API Configuration
MOCK_API_PORT=8000
MOCK_API_HOST=localhost

# Application
LOG_LEVEL=INFO
